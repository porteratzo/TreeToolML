            //"justMyCode": false,
            "args": [
                "--cfg",
                "configs/datasets/trunks.yaml",
                "--amp",
                "1",
                "--resume",
                "1",
                "--device",
                "gpu",
                "TRAIN.BATCH_SIZE",
                "4",
                "VALIDATION.BATCH_SIZE",
                "16",
            ]
        },
        {
            "name": "Python: Train",
            "type": "python",
            "request": "launch",
            "program": "scripts/PDE_train.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--cfg",
                "configs/experimentos_model/subconfigs/distance_out_loss.yaml",
                "--amp",
                "1",
                "--resume",
                "1",
                "--device",
                "gpu",
                "TRAIN.BATCH_SIZE",
                "10",
                "VALIDATION.BATCH_SIZE",
                "10",
                "TRAIN.EPOCHS", "150"
            ]
        },
        {
            "name": "Python: Test",
            "type": "python",
            "request": "launch",
            "program": "scripts/PDE_test.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--cfg",
                "configs/datasets/subconfigs/trunks.yaml",
                //"configs/experimentos_model/subconfigs/distance_out.yaml",
                "--amp",
                "1",
                "--device",
                "gpu",
                "TRAIN.BATCH_SIZE",
                "1",
                "VALIDATION.BATCH_SIZE",
                "1"
            ]
        },
        {
            "name": "Python: Vis",
            "type": "python",
            "request": "launch",
            "program": "scripts/Tree_visualize.py",
            "console": "integratedTerminal",
            "args": [
                "--cfg",
                "configs/datasets/trunks.yaml",
                "--amp",
                "0",
                "--device",
                "gpu",
                "TRAIN.BATCH_SIZE",
                "4"
            ]
        },
        {
            "name": "Python: make",
            "type": "python",
            "request": "launch",
            "program": "scripts/datapreparation/make_PDE_dataset_3.py",
            "console": "integratedTerminal",
            "args": [
                "--cfg",
                "configs/datasets/trunks.yaml",
            ]
        },
        {
            "name": "Python: bench",
            "type": "python",
            "request": "launch",
            "program": "notebooks/benchmarking/benchmark_treetoolml.py",
            "console": "integratedTerminal",
            "args": [
                "--cfg",
                //"configs/experimentos_voxelsize/subconfigs/baseline_small.yaml",
